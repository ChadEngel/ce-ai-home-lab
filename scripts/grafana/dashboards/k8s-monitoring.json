{
  "id": null,
  "title": "CE AI Lab – Kubernetes Monitoring",
  "tags": ["kubernetes", "influx"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Running Pods",
      "datasource": "InfluxDB",  
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT mean(\"running\") FROM \"kube_metrics\" WHERE $timeFilter GROUP BY time($__interval)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CPU Usage %",
      "datasource": "InfluxDB",  
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT mean(\"cpu_usage_pct\") FROM \"kube_metrics\" WHERE $timeFilter GROUP BY time($__interval)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory Free %",
      "datasource": "InfluxDB",  
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT mean(\"mem_free_pct\") FROM \"kube_metrics\" WHERE $timeFilter GROUP BY time($__interval)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Node Uptime (Seconds)",
      "datasource": "InfluxDB",  
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 5},
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT mean(\"nodes_uptime_sec\") FROM \"kube_metrics\" WHERE $timeFilter GROUP BY time($__interval)"
        }
      ]
    }
  ],
  "schemaVersion": 30,
  "version": 1
}

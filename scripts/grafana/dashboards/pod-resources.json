{
  "id": null,
  "uid": "ceai-pod-resources",
  "title": "CE AI Lab - Pod Resources & OOM Monitoring",
  "tags": [
    "kubernetes",
    "homelab",
    "pods",
    "resources"
  ],
  "timezone": "browser",
  "refresh": "60s",
  "style": "dark",
  "schemaVersion": 36,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "cluster_datasource",
        "type": "datasource",
        "query": "influxdb",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": true,
        "refresh": 1,
        "regex": "",
        "sort": 0,
        "label": "Data Source"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "$cluster_datasource"
        },
        "query": "from(bucket: \"kube_metrics\") |> range(start: -5m) |> filter(fn: (r) => r._measurement == \"k8s_pod_requests\" or r._measurement == \"k8s_pod_resources\") |> keep(columns: [\"namespace\"]) |> distinct(column: \"namespace\") |> sort(desc: true)",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": true,
        "refresh": 1,
        "regex": "",
        "sort": 2,
        "label": "Namespace"
      }
    ]
  },
  "panels": [
    {
      "id": 101,
      "type": "table",
      "title": "Pod CPU/Memory Overview (All Namespaces)",
      "datasource": {
        "type": "influxdb",
        "uid": "$cluster_datasource"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "$cluster_datasource"
          },
          "rawQuery": true,
          "query": "from(bucket: \"kube_metrics\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"k8s_pod_resources\") |> group(columns: [\"_start\", \"_stop\"]) >| pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\") |> last()"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "_start": true,
              "_stop": true,
              "_field": false,
              "_measurement": false
            },
            "indexByName": {},
            "renameBy": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cpu_millicores"
            },
            "properties": [
              {
                "id": "unit",
                "value": "millicores"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "memory_kb"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Total Pod Memory Usage (KB)",
      "datasource": {
        "type": "influxdb",
        "uid": "$cluster_datasource"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "$cluster_datasource"
          },
          "rawQuery": true,
          "query": "from(bucket: \"kube_metrics\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"k8s_pod_resources\" and r._field == \"memory_kb\") |> aggregateWindow(every: 1m, fn: sum)"
        }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Total Pod CPU (millicores)",
      "datasource": {
        "type": "influxdb",
        "uid": "$cluster_datasource"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "$cluster_datasource"
          },
          "rawQuery": true,
          "query": "from(bucket: \"kube_metrics\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"k8s_pod_resources\" and r._field == \"cpu_millicores\") |> aggregateWindow(every: 1m, fn: sum)"
        }
      ]
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Pods with Restarts (OOMKilled suspects)",
      "datasource": {
        "type": "influxdb",
        "uid": "$cluster_datasource"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "$cluster_datasource"
          },
          "rawQuery": true,
          "query": "from(bucket: \"kube_metrics\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"k8s_pod_restarts\" and r.count > 0)"
        }
      ]
    },
    {
      "id": 105,
      "type": "timeseries",
      "title": "Pod Memory Trend (All Pods)",
      "datasource": {
        "type": "influxdb",
        "uid": "$cluster_datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "$cluster_datasource"
          },
          "rawQuery": true,
          "query": "from(bucket: \"kube_metrics\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"k8s_pod_resources\" and r._field == \"memory_kb\") |> aggregateWindow(every: 1m, fn: sum)"
        }
      ]
    },
    {
      "id": 106,
      "type": "timeseries",
      "title": "Pod CPU Trend (All Pods)",
      "datasource": {
        "type": "influxdb",
        "uid": "$cluster_datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "$cluster_datasource"
          },
          "rawQuery": true,
          "query": "from(bucket: \"kube_metrics\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"k8s_pod_resources\" and r._field == \"cpu_millicores\") |> aggregateWindow(every: 1m, fn: sum)"
        }
      ]
    },
    {
      "id": 107,
      "type": "table",
      "title": "Pod Restarts (OOMKilled Detection)",
      "datasource": {
        "type": "influxdb",
        "uid": "$cluster_datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "$cluster_datasource"
          },
          "rawQuery": true,
          "query": "from(bucket: \"kube_metrics\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"k8s_pod_restarts\" and r.count > 0) |> group() |> last()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "count"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              }
            ]
          }
        ]
      }
    }
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "description": "Per-pod and per-namespace CPU/memory resource tracking. Critical for detecting OOMKilled pods and resource exhaustion in services like open-webui.",
  "schemaVersion": 36,
  "version": 1
}

    {
      "id": 8,
      "type": "table",
      "title": "Pod Inventory (running pods \u2014 CPU, memory, restarts)",
      "datasource": {
        "type": "influxdb",
        "uid": "dfdkew37wk1dse"
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "query": "resources = from(bucket: \"kube_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"k8s_pod_resources\")\n  |> filter(fn: (r) => r._field == \"cpu_millicores\" or r._field == \"memory_kb\")\n  |> group(columns: [\"namespace\", \"pod\", \"_field\"])\n  |> last()\n  |> pivot(rowKey: [\"namespace\", \"pod\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n\nrestarts = from(bucket: \"kube_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"k8s_pod_restarts\")\n  |> group(columns: [\"namespace\", \"pod\"])\n  |> last()\n  |> keep(columns: [\"namespace\", \"pod\", \"_value\"])\n  |> rename(columns: {_value: \"restarts\"})\n\njoin(tables: {resources: resources, restarts: restarts}, on: [\"namespace\", \"pod\"])\n  |> keep(columns: [\"namespace\", \"pod\", \"cpu_millicores\", \"memory_kb\", \"restarts\"])\n  |> sort(columns: [\"namespace\", \"pod\"])",
          "queryType": "flux",
          "datasource": {
            "type": "influxdb",
            "uid": "dfdkew37wk1dse"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "namespace"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "pod"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 320
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cpu_millicores"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "displayName",
                "value": "CPU (millicores)"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "memory_kb"
            },
            "properties": [
              {
                "id": "unit",
                "value": "kbytes"
              },
              {
                "id": "displayName",
                "value": "Memory"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "restarts"

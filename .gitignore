# Never commit cluster backups / snapshots — they can contain Kubernetes
# Secret material (TLS private keys, service-account tokens, helm release
# secrets). Keep them out of the repo entirely.
backups/

# Local scratch / export dirs
exports/
tmp/

# Editor / OS noise
.DS_Store
*.swp
*~

# Local secret material (Infisical token cache, downloaded keys, etc.)
.cache/
*.pem
*.key
id_rsa*
id_ed25519*